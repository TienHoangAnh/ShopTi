# Copy to .env and fill values:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Mac/Linux)

# --- Express local: chọn DB ---
# sqlite  = backend SQLite (mặc định)
# mongodb = Express dùng Mongoose — PHẢI đổi DB_TYPE=mongodb, chỉ có MONGODB_URI là KHÔNG đủ
DB_TYPE=sqlite

# MongoDB — bắt buộc khi DB_TYPE=mongodb (Vercel / seed cũng cần URI)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/shopti?retryWrites=true&w=majority

# JWT (auth) – đổi production
JWT_SECRET=change-me-in-production

# Port Express (tùy chọn)
# PORT=3000

# Mapbox (bản đồ checkout – tùy chọn, có token mặc định)
# MAPBOX_ACCESS_TOKEN=pk.eyJ...
